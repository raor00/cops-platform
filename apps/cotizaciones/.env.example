AI_PROVIDER_MODE=hybrid

# Ollama local o remoto (ej. VPS Hetzner)
OLLAMA_BASE_URL=http://localhost:11434
# Modelos válidos dependen de lo que realmente exista en tu servidor.
# Ejemplos comunes en Ollama: qwen3.5:4b, qwen3:4b, gemma4:e4b
OLLAMA_MODEL=qwen3.5:2b
OLLAMA_TIMEOUT_MS=120000
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_TIMEOUT_MS=12000

# Gemini fallback
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=30000

# API protection
AI_RATE_LIMIT_PER_MIN=20

# Knowledge Base (RAG)
AI_KNOWLEDGE_ENABLED=false
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
