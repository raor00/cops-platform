# Local mode (sin Supabase)
TICKETS_LOCAL_MODE=true
NEXT_PUBLIC_TICKETS_LOCAL_MODE=true
TICKETS_DEMO_USERNAME=admin
TICKETS_DEMO_EMAIL=admin@copselectronics.com
TICKETS_DEMO_PASSWORD=admin123

# Supabase (opcional en modo local, requerido para modo real)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Cloudinary (recomendado para fotos/documentos en modo real)
# Usa UNA de estas dos opciones:
# 1) Credenciales firmadas del servidor
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# 2) O upload preset unsigned
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# URLs de las otras apps (requeridas para navegacion y SSO)
WEB_URL=https://cops-platform-web.vercel.app
COTIZACIONES_URL=https://cops-platform-cotizaciones.vercel.app
NEXT_PUBLIC_PLATFORM_COTIZACIONES_URL=https://cops-platform-cotizaciones.vercel.app
PLATFORM_TICKETS_BRIDGE_SECRET=replace-with-the-same-secret-used-in-web
