# ─── apps/cotizaciones — Producción Hetzner ──────────────────
# Copia este archivo como apps/cotizaciones/.env.local en el VPS

# Ollama en el MISMO servidor Hetzner (localhost)
AI_PROVIDER_MODE=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:2b
OLLAMA_TIMEOUT_MS=180000
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_TIMEOUT_MS=12000

# Gemini (opcional — solo si quieres fallback manual cambiando AI_PROVIDER_MODE=hybrid)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=30000

# Rate limiting API
AI_RATE_LIMIT_PER_MIN=20

# Knowledge Base RAG (desactivado por defecto)
AI_KNOWLEDGE_ENABLED=false
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
