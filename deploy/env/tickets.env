# ─── apps/tickets — Producción Hetzner ───────────────────────
# Copia este archivo como apps/tickets/.env.local en el VPS

# Firebase mode activo (cambia a true para usar mock data local)
TICKETS_LOCAL_MODE=false
NEXT_PUBLIC_TICKETS_LOCAL_MODE=false

# Firebase Client SDK
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyCkxGHytPvbd1ZoCXGuLKoS_PW6QkkOnFM
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=cops-platform-1c34a.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=cops-platform-1c34a
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=cops-platform-1c34a.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=86544319076
NEXT_PUBLIC_FIREBASE_APP_ID=1:86544319076:web:57fc162f924a772b9b5571

# Firebase Admin SDK (obtener de Firebase Console -> Cuentas de servicio)
FIREBASE_PROJECT_ID=cops-platform-1c34a
FIREBASE_CLIENT_EMAIL=REEMPLAZAR_CON_SERVICE_ACCOUNT_EMAIL
FIREBASE_PRIVATE_KEY="REEMPLAZAR_CON_PRIVATE_KEY_CON_SALTOS_DE_LINEA"

# Bridge SSO desde Web (mismo valor que en web.env)
PLATFORM_TICKETS_BRIDGE_SECRET=REEMPLAZAR_CON_SECRETO_LARGO_ALEATORIO

# URLs de los otros modulos
WEB_URL=https://copselectronics.com
COTIZACIONES_URL=https://cotizaciones.copselectronics.com
