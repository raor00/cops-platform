# ─── apps/tickets — Producción Hetzner ───────────────────────
# Copia este archivo como apps/tickets/.env.local en el VPS

TICKETS_LOCAL_MODE=true
NEXT_PUBLIC_TICKETS_LOCAL_MODE=true
TICKETS_DEMO_EMAIL=admin@copselectronics.com
TICKETS_DEMO_PASSWORD=REEMPLAZAR_CON_PASSWORD_SEGURO

# Bridge SSO desde Web (mismo valor que en web.env)
PLATFORM_TICKETS_BRIDGE_SECRET=REEMPLAZAR_CON_SECRETO_LARGO_ALEATORIO

# URLs de los otros módulos
WEB_URL=https://copselectronics.com
COTIZACIONES_URL=https://cotizaciones.copselectronics.com
NEXT_PUBLIC_PLATFORM_COTIZACIONES_URL=https://cotizaciones.copselectronics.com
